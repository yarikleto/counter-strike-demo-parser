{
  "name": "counter-strike-demo-parser",
  "version": "0.0.1",
  "description": "TypeScript library for parsing CS:GO .dem files. Streaming event-emitter architecture, fully typed, minimal dependencies.",
  "author": "Yaroslav Pakhaliuk",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "native/binding.gyp",
    "native/src",
    "native/README.md"
  ],
  "gypfile": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "build:native": "node-gyp configure --directory native && node-gyp build --directory native",
    "rebuild:native": "node-gyp rebuild --directory native",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "generate:proto": "bash scripts/generate-proto.sh",
    "bench": "npx tsx scripts/benchmark.ts",
    "goldens:update": "npx tsx scripts/generate-goldens.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "node-gyp": "^10.2.0",
    "prettier": "^3.0.0",
    "ts-proto": "^1.181.2",
    "tsup": "^8.0.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "csgo",
    "counter-strike",
    "demo",
    "parser",
    "dem",
    "replay",
    "valve",
    "source-engine"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yarikleto/counter-strike-demo-parser.git"
  },
  "dependencies": {
    "node-addon-api": "^8.2.0",
    "protobufjs": "^8.0.3",
    "snappyjs": "^0.7.0"
  }
}
